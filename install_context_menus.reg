; ── Folder right-click: Convert All to JPG ───────────────────────────────────
[HKEY_CLASSES_ROOT\Directory\shell\ConvertAllToJPG]
@="Convert All to JPG"
"Icon"="shell32.dll,47"

[HKEY_CLASSES_ROOT\Directory\shell\ConvertAllToJPG\command]
@="\"C:\\Python314\\pythonw.exe\" \"C:\\Users\\MFurq\\Scripts\\folder_to_jpg.py\" \"%1\""

; ── Inside-folder right-click: Convert All to JPG ────────────────────────────
[HKEY_CLASSES_ROOT\Directory\Background\shell\ConvertAllToJPG]
@="Convert All to JPG"
"Icon"="shell32.dll,47"

[HKEY_CLASSES_ROOT\Directory\Background\shell\ConvertAllToJPG\command]
@="\"C:\\Python314\\pythonw.exe\" \"C:\\Users\\MFurq\\Scripts\\folder_to_jpg.py\" \"%V\""
